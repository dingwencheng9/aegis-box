# 🛡️ Aegis Box - Environment Variables Template
#
# This file is a template for your local .env file.
# Copy this file to .env and fill in your actual values.
#
# Usage:
#   cp .env.example .env
#   # Then edit .env with your real API keys
#
# Security:
#   - NEVER commit .env to version control
#   - .env is already in .gitignore
#
# ==========================================

# ==========================================
# API Keys (Required)
# ==========================================

# Anthropic Claude API Key
# Get it from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API Key (Optional - if using GPT models)
# Get it from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key-here

# 智谱 AI API Key (Optional - if using GLM models)
# Get it from: https://open.bigmodel.cn/
ZHIPU_API_KEY=your-zhipu-api-key-here

# ==========================================
# Model Configuration (Optional)
# ==========================================
# Override model IDs for each tier
# If not set, uses defaults from aegis.yaml
#
# Tier 1: Fast scanning and initial analysis
# Tier 2: Main reasoning and architecture summary
# Tier 3: Deep reasoning and patch generation

# Recommended Configuration (Cost-Optimized)
ZHIPU_MODEL_TIER1=glm-4-air
ANTHROPIC_MODEL_TIER2=claude-3-5-haiku-20241022
ANTHROPIC_MODEL_TIER3=claude-3-5-sonnet-20241022

# Alternative: High-Performance Configuration
# ANTHROPIC_MODEL_TIER1=claude-3-5-haiku-20241022
# ANTHROPIC_MODEL_TIER2=claude-3-5-sonnet-20241022
# ANTHROPIC_MODEL_TIER3=claude-opus-4-8

# ==========================================
# API Endpoints (Optional)
# ==========================================
# Custom endpoints for private deployments or proxies

# Anthropic API Base URL
# ANTHROPIC_API_URL=https://api.anthropic.com

# Zhipu API Base URL
# ZHIPU_API_URL=https://open.bigmodel.cn/api/paas/v4

# OpenAI API Base URL
# OPENAI_API_BASE=https://api.openai.com/v1

# ==========================================
# Local LLM Configuration (Ollama)
# ==========================================
# For privacy-first, 100% offline operation

# Ollama Base URL (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# Example: Full Ollama Configuration
# TIER1_FAST_PROVIDER=ollama
# TIER1_FAST_MODEL=llama3:8b
# TIER2_REASONING_PROVIDER=ollama
# TIER2_REASONING_MODEL=codellama:34b
# TIER3_PATCHING_PROVIDER=ollama
# TIER3_PATCHING_MODEL=qwen:72b

# ==========================================
# Advanced Configuration (Optional)
# ==========================================

# Rate Limiting (requests per minute)
# AEGIS_GLOBAL_QPS=10
# AEGIS_ANTHROPIC_RPM=40
# AEGIS_OPENAI_RPM=50

# Git Sandbox Configuration
# AEGIS_AUTO_STASH=true
# AEGIS_BRANCH_PREFIX=aegis-patch

# Logging Level (DEBUG, INFO, WARNING, ERROR)
# AEGIS_LOG_LEVEL=INFO

