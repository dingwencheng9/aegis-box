# Aegis Box - 环境变量配置

# ==========================================
# Anthropic API Configuration
# ==========================================
# 获取方式: https://console.anthropic.com/
# 用于: Claude 模型 (Tier 2/3)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# 自定义 API 端点（可选，默认使用官方端点）
# 如果使用代理或转发服务，请取消注释并填入正确的 URL
ANTHROPIC_API_URL=https://cdn1.yunyi.yun/claude

# 模型配置（可选，使用默认模型如果未设置）
# 常见模型:
# - claude-3-5-sonnet-20240620 (最新，高质量)
# - claude-3-sonnet-20240229 (稳定)
# - claude-3-haiku-20240307 (快速，便宜)
ANTHROPIC_MODEL_TIER2=claude-3-haiku-20240307
ANTHROPIC_MODEL_TIER3=claude-3-5-sonnet-20240620

# ==========================================
# Zhipu AI API Configuration
# ==========================================
# 获取方式: https://open.bigmodel.cn/
# 用于: GLM 模型 (Tier 1)
ZHIPU_API_KEY=your-zhipu-api-key-here

# 模型配置（可选，使用默认模型如果未设置）
# 常见模型:
# - glm-4-air (最快，最便宜，推荐)
# - glm-4-flash (快速，平衡)
# - glm-4 (标准)
# - glm-4-plus (高级)
ZHIPU_MODEL_TIER1=glm-4-air

# ==========================================
# OpenAI API Configuration (可选)
# ==========================================
# 获取方式: https://platform.openai.com/
# 用于: GPT 模型 (备选)
# OPENAI_API_KEY=your-openai-api-key-here

# ==========================================
# API Endpoints (可选，使用默认值)
# ==========================================
# ANTHROPIC_API_URL=https://api.anthropic.com
# ZHIPU_API_URL=https://open.bigmodel.cn/api/paas/v4
